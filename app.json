{
  "expo": {
    "name": "ResetDopa",
    "slug": "resetdopa",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "description": "Your companion for dopamine detox and habit building. Track urges, complete daily tasks, and build lasting streaks.",
    "primaryColor": "#4A90E2",
    "jsEngine": "hermes",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "updates": {
      "url": "https://u.expo.dev/resetdopa"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.dopareset.app",
      "buildNumber": "1.0.0",
      "infoPlist": {
        "UIBackgroundModes": [
          "remote-notification"
        ],
        "NSMotionUsageDescription": "DopaReset uses your step count to track daily activity and encourage healthy movement habits."
      }
    },
    "android": {
      "package": "com.dopareset.app",
      "versionCode": 13,
      "jsEngine": "hermes",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#000000"
      },
      "permissions": [
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE",
        "SCHEDULE_EXACT_ALARM",
        "POST_NOTIFICATIONS",
        "ACTIVITY_RECOGNITION",
        "BODY_SENSORS"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#4A90E2",
          "sounds": []
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "compileSdkVersion": 35,
            "targetSdkVersion": 35,
            "buildToolsVersion": "35.0.0",
            "minSdkVersion": 24,
            "kotlinVersion": "2.2.20"
          },
          "ios": {
            "deploymentTarget": "15.1"
          }
        }
      ],
      "expo-font",
      "expo-asset"
    ],
    "extra": {
      "privacyPolicyUrl": "https://resetdopa.com/privacy.html",
      "termsUrl": "https://resetdopa.com/terms.html",
      "eas": {
        "projectId": "de4ee721-5de6-46b5-9533-63ac1b808ac3"
      }
    },
    "runtimeVersion": "1.0.0",
    "scheme": "com.dopareset.app",
    "owner": "p18k"
  }
}
